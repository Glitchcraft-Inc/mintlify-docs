{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "modeToggle": {
    "default": "dark"
  },
  "name": "Actioneer Docs",
  "description": "Enterprise AI that answers any data question and acts on it.",
  "colors": {
    "primary": "#5F7A6A",
    "light": "#8BA697",
    "dark": "#4C6657"
  },
  "background": {
    "color": {
      "light": "#F7F5EF",
      "dark": "#0E0F0F"
    }
  },
  "font": {
    "headings": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/how-actioneer-reads-your-data",
              "concepts/identity-resolution",
              "concepts/ingestion-vs-warehouse"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Data Sources",
            "pages": [
              "integrations/data-warehouses",
              "integrations/data-warehouses/amazon-athena",
              "integrations/data-warehouses/amazon-redshift",
              "integrations/data-warehouses/s3",
              "integrations/data-warehouses/clickhouse",
              "integrations/data-warehouses/databricks",
              "integrations/data-warehouses/google-big-query",
              "integrations/data-warehouses/google-cloud-storage",
              "integrations/data-warehouses/google-sheets",
              "integrations/data-warehouses/postgresql",
              "integrations/data-warehouses/snowflake"
            ]
          },
          {
            "group": "MMP Connections",
            "pages": [
              "integrations/mmp",
              "integrations/mmp/adjust",
              "integrations/mmp/appsflyer",
              "integrations/mmp/singular"
            ]
          }
        ]
      },
      {
        "tab": "Event Ingestion",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "ingestion"
            ]
          },
          {
            "group": "API Reference",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "ingestion/api-reference",
              "ingestion/endpoints/capture",
              "ingestion/endpoints/batch",
              "ingestion/errors"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "ingestion/identity",
              "ingestion/properties",
              "ingestion/reliability",
              "ingestion/sending-events"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Help",
            "pages": [
              "support",
              "faq",
              "changelog",
              "resources/ask-actioneer"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/access-and-networking",
              "operations/glossary"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": []
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "metatags": {
      "og:site_name": "Actioneer Docs",
      "og:type": "website",
      "twitter:card": "summary_large_image",
      "twitter:site": "@actioneerhq",
      "robots": "index, follow",
      "canonical": "https://docs.actioneer.com"
    },
    "indexing": "all"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/actioneerhq",
      "linkedin": "https://www.linkedin.com/company/actioneer-hq/"
    }
  }
}
