{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Actioneer Docs",
  "description": "Connect your data warehouses and BI tools to Actioneer.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Data Warehouse Integrations",
        "icon": "database",
        "expanded": true,
        "pages": [
          "integrations/data-warehouses",
          "integrations/data-warehouses/amazon-redshift",
          "integrations/data-warehouses/s3",
          "integrations/data-warehouses/databricks",
          "integrations/data-warehouses/google-big-query",
          "integrations/data-warehouses/snowflake"
        ]
      },
      {
        "group": "BI Tool Integrations",
        "icon": "chart-bar",
        "expanded": true,
        "pages": [
          "integrations/bi-tools",
          "integrations/bi-tools/amplitude",
          "integrations/bi-tools/mixpanel",
          "integrations/bi-tools/power-bi"
        ]
      },
      {
        "group": "About",
        "icon": "info",
        "pages": [
          "about"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
